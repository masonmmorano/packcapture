# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# PackCapture
# Built set bundles are ignored by default (local/scratch builds). Prebuilt
# bundles for supported sets are force-added (git add -f sets/<code>) and tracked
# thereafter; long-term these migrate to GitHub release assets + auto-fetch.
sets/
*.npy
*.db
!tests/**/*.db

# Local scratch / sample captures
scratch/
samples/

# Local-only real-footage test fixtures (third-party video frames; kept out of
# the public repo for provenance/IP reasons). The README that documents how to
# regenerate them IS tracked; the images are not.
tests/assets/*.png
tests/assets/*.jpg
tests/assets/*.jpeg

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
